{
  "name": "signal-desk",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "node scripts/clean-api-js.mjs && npx vercel dev --listen 3001 --yes",
    "build": "tsc && tsc -p api/tsconfig.json && vite build",
    "preview": "vite preview",
    "setup:headless": "npx playwright install chromium",
    "db:migrate": "tsx db/migrate.ts",
    "db:verify": "tsx scripts/verify-db.ts"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/diff": "^7.0.2",
    "@types/node": "^26.1.0",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vercel/node": "^5.8.22",
    "@vitejs/plugin-react": "^6.0.3",
    "tsx": "^4.23.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "diff": "^9.0.0",
    "inngest": "^4.11.0",
    "jose": "^6.2.3",
    "nodemailer": "^9.0.3",
    "openai": "^6.45.0",
    "playwright": "^1.61.1",
    "postgres": "^3.4.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "resend": "^6.17.2",
    "zod": "^4.4.3",
    "zod-to-json-schema": "^3.25.2"
  }
