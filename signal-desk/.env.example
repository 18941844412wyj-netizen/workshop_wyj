# Supabase — API / Serverless 推荐 Transaction pooler（端口 6543）
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true

# 本地执行 db:migrate 时可用直连（Supabase Dashboard → Settings → Database → Connection string → URI）
# DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

SESSION_SECRET=replace_me_dev_secret_32chars_min
LLM_API_KEY=
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
LLM_MODEL=glm-4-flash
# 邮件推送（SMTP，如 QQ/163 邮箱）
# QQ：SMTP_HOST=smtp.qq.com  SMTP_PORT=465  SMTP_USER=你的QQ邮箱  SMTP_PASS=授权码（非登录密码）
# 163：SMTP_HOST=smtp.163.com SMTP_PORT=465 SMTP_USER=你的163邮箱 SMTP_PASS=授权码
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=replace_me
# 可选：SMTP_SECURE=true（465 默认 true，587 设为 false）
# SMTP_SECURE=
# 可选：发件显示名与发件地址（默认地址=SMTP_USER）
SMTP_FROM_NAME=Signal Desk
# SMTP_FROM=
# 邮件内“查看详情”链接的站点地址
APP_URL=http://localhost:5173

CRON_SECRET=dev_cron_local_test_secret

# Inngest（页面变化检测调度，每 5 分钟触发）
# 注册地址：https://app.inngest.com → 创建 App → Event Key / Signing Key
# 本地开发：运行 npx inngest-cli@latest dev 后填入 Dev Server 的 key
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# 可选：headless 采集
# HEADLESS_ENABLED=true
# HEADLESS_TIMEOUT_MS=30000
# BROWSER_RENDER_URL=
